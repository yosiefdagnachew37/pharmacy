# LAN Server Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to lan-server.env and fill in your values.
# Then run: pm2 start ecosystem.config.js
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment Mode ───────────────────────────────────────────────────────────
# REQUIRED: Must be exactly "lan-server" for this deployment type
DEPLOYMENT_MODE=lan-server

# ── Server Port ───────────────────────────────────────────────────────────────
# Port the backend will listen on (binds to 0.0.0.0 automatically in lan-server mode)
# Client PCs must be able to reach SERVER_PC_IP:PORT
PORT=3000

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# External PostgreSQL installed on the server PC (NOT embedded)
# Install PostgreSQL 15 or later from: https://www.postgresql.org/download/windows/
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=pharmacy_user
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
DB_NAME=pharmacy_lan_db

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Must be a strong random string — all client sessions depend on this
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS_MINIMUM

# ── LAN Shared Secret Token ────────────────────────────────────────────────────
# All client PCs must send this value in the x-lan-secret HTTP header.
# Set this in the LAN Setup screen on each client PC.
# Leave blank to disable server-side secret validation (NOT recommended).
LAN_SECRET=CHANGE_THIS_TO_A_SHARED_SECRET

# ── DO NOT SET THESE IN LAN SERVER MODE ───────────────────────────────────────
# IS_DESKTOP_OFFLINE must NOT be set — hardware license is not used in LAN mode
# The license system is bypassed; access control is via LAN_SECRET + user credentials
# IS_DESKTOP_OFFLINE=true   ← DO NOT UNCOMMENT THIS LINE
